generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(user)
  createdAt DateTime  @default(now())
  cultivos  Cultivo[]
  reportes  Reporte[]
  darkMode  Boolean   @default(false)
  language  String?   @default("es")
  farmName  String?
  location  String?
}

model Cultivo {
  id              Int            @id @default(autoincrement())
  nombre          String
  descripcion     String?
  fechaSiembra    DateTime
  ubicacion       String
  frecuenciaRiego Int
  estado          EstadoCultivo  @default(activo)
  userId          Int
  createdAt       DateTime       @default(now())
  imagen          String?

  user     User      @relation(fields: [userId], references: [id])
  reportes Reporte[]
}

model Reporte {
  id          Int          @id @default(autoincrement())
  titulo      String
  descripcion String
  tipo        TipoReporte
  imagen      String?
  cultivoId   Int
  userId      Int
  createdAt   DateTime     @default(now())

  cultivo Cultivo @relation(fields: [cultivoId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])
}

enum TipoReporte {
  RIEGO
  FERTILIZACION
  PLAGA
  COSECHA
  OBSERVACION
}

enum Role {
  admin
  user
}

enum EstadoCultivo {
  activo
  inactivo
  cosechado
  perdido
}